# max empty content before giving up, default 8
MAX_EMPTY_RESPONSES=
# invoke_subagent timeout in minutes, default 10, hard cap 60
MAX_SUBAGENT_TIMEOUT_MIN=
# external CLI agent (codex/claude/copilot/gemini) timeout in minutes, default 10, hard cap 60
MAX_EXTERNAL_AGENT_TIMEOUT_MIN=

EXTERNAL_COPILOT=
EXTERNAL_CLAUDE=
