{
  "name": "hackernews_item",
  "description": "Get a Hacker News item by ID from the Firebase API.",
  "endpoint": {
    "url": "https://hacker-news.firebaseio.com/v0/item/{id}.json",
    "method": "GET",
    "content_type": "json",
    "timeout": 10
  },
  "parameters": {
    "id": {
      "type": "integer",
      "description": "Hacker News item ID.",
      "required": true
    }
  },
  "response": {
    "format": "json"
  }
}
