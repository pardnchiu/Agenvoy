{
  "name": "open_meteo",
  "description": "Get current weather and forecast data for the specified coordinates from Open-Meteo.",
  "endpoint": {
    "url": "https://api.open-meteo.com/v1/forecast",
    "method": "GET",
    "content_type": "json",
    "timeout": 10
  },
  "parameters": {
    "latitude": {
      "type": "number",
      "description": "Latitude in WGS84 (-90 to 90).",
      "required": true
    },
    "longitude": {
      "type": "number",
      "description": "Longitude in WGS84 (-180 to 180).",
      "required": true
    },
    "current": {
      "type": "string",
      "description": "Comma-separated current-weather variables (for example, 'temperature_2m,relative_humidity_2m,precipitation,weather_code,wind_speed_10m').",
      "required": false,
      "default": ""
    },
    "hourly": {
      "type": "string",
      "description": "Comma-separated hourly forecast variables (for example, 'temperature_2m,precipitation_probability,weather_code').",
      "required": false,
      "default": ""
    },
    "daily": {
      "type": "string",
      "description": "Comma-separated daily statistics variables (for example, 'temperature_2m_max,temperature_2m_min,precipitation_sum'). Requires timezone.",
      "required": false,
      "default": ""
    },
    "timezone": {
      "type": "string",
      "description": "IANA timezone such as 'Asia/Taipei' or 'America/New_York'. Use 'auto' to detect. Required when daily is set.",
      "required": false,
      "default": "auto"
    },
    "forecast_days": {
      "type": "integer",
      "description": "Number of forecast days (0-16).",
      "required": false,
      "default": 7
    },
    "past_days": {
      "type": "integer",
      "description": "Number of past days to include (0-92).",
      "required": false,
      "default": 0
    },
    "temperature_unit": {
      "type": "string",
      "description": "Temperature unit.",
      "required": false,
      "default": "celsius",
      "enum": ["celsius", "fahrenheit"]
    },
    "wind_speed_unit": {
      "type": "string",
      "description": "Wind speed unit.",
      "required": false,
      "default": "kmh",
      "enum": ["kmh", "ms", "mph", "kn"]
    },
    "precipitation_unit": {
      "type": "string",
      "description": "Precipitation unit.",
      "required": false,
      "default": "mm",
      "enum": ["mm", "inch"]
    }
  },
  "response": {
    "format": "json"
  }
}
