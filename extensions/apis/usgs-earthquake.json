{
  "name": "usgs_earthquake",
  "description": "Query real-time or historical earthquake data from the USGS Earthquake Hazards API.",
  "endpoint": {
    "url": "https://earthquake.usgs.gov/fdsnws/event/1/query",
    "method": "GET",
    "content_type": "json",
    "timeout": 15
  },
  "parameters": {
    "format": {
      "type": "string",
      "description": "Response format.",
      "required": false,
      "default": "geojson",
      "enum": ["geojson", "csv", "text"]
    },
    "starttime": {
      "type": "string",
      "description": "Start time in ISO 8601 format (for example, '2024-01-01' or '2024-01-01T00:00:00').",
      "required": false,
      "default": ""
    },
    "endtime": {
      "type": "string",
      "description": "End time in ISO 8601 format. Defaults to now when omitted.",
      "required": false,
      "default": ""
    },
    "minmagnitude": {
      "type": "number",
      "description": "Minimum magnitude on the Richter scale (for example, 5.0).",
      "required": false,
      "default": 0
    },
    "maxmagnitude": {
      "type": "number",
      "description": "Maximum magnitude on the Richter scale.",
      "required": false,
      "default": 0
    },
    "latitude": {
      "type": "number",
      "description": "Center latitude, used together with longitude and maxradiuskm.",
      "required": false,
      "default": 0
    },
    "longitude": {
      "type": "number",
      "description": "Center longitude.",
      "required": false,
      "default": 0
    },
    "maxradiuskm": {
      "type": "number",
      "description": "Search radius in kilometers (maximum 20001.6).",
      "required": false,
      "default": 0
    },
    "limit": {
      "type": "integer",
      "description": "Maximum number of results to return (maximum 20000).",
      "required": false,
      "default": 20
    },
    "orderby": {
      "type": "string",
      "description": "Sort order.",
      "required": false,
      "default": "time",
      "enum": ["time", "time-asc", "magnitude", "magnitude-asc"]
    }
  },
  "response": {
    "format": "json"
  }
}
